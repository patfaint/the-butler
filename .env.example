# Discord bot credentials
DISCORD_TOKEN=

# Your Discord server (guild) ID — right-click your server icon → Copy Server ID
GUILD_ID=

# Tenor API key for GIF reactions (https://developers.google.com/tenor)
TENOR_API_KEY=

# SQLite database path (default works for local dev and most AWS setups)
DATABASE_URL=sqlite+aiosqlite:///./butler.db
